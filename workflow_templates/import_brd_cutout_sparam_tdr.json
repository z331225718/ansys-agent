{
  "template_id": "import_brd_cutout_sparam_tdr",
  "name": "3D Layout BRD/MCM Cutout Model Build",
  "description": "Import a Cadence BRD/MCM file, select nets, create a cutout, configure stackup, ports, setup, and sweep without running solve.",
  "scenario": "High-speed board workflow for imported BRD/MCM designs.",
  "tags": ["hfss-3d-layout", "brd", "mcm", "cutout", "model-build"],
  "validation_checks": ["layout_imported", "nets_selected", "cutout_created", "stackup_configured", "layout_ports_created", "layout_setup_created"],
  "known_limits": [
    "Real stackup edits and port placement are board-specific and require board rules after the import/cutout step.",
    "This demo intentionally stops before analyze so the generated model can be inspected on resource-limited machines."
  ],
  "workflow": {
    "workflow_id": "import_brd_cutout_sparam_tdr_v1",
    "name": "Import BRD/MCM Cutout Model Build",
    "version": "0.1.0",
    "description": "Controlled 3D Layout workflow for imported high-speed board cutout model generation.",
    "parameters": [
      {
        "name": "layout_file",
        "type": "string",
        "default": "/home/zzmjay/work/brd/c03010211_56g_2512031835.brd",
        "label": "BRD/MCM file"
      },
      {
        "name": "signal_nets",
        "type": "string",
        "default": "SRDS_3_RX1_*",
        "label": "Signal net wildcard"
      },
      {
        "name": "reference_nets",
        "type": "string",
        "default": "GND",
        "label": "Reference nets"
      },
      {
        "name": "stackup_xml",
        "type": "string",
        "default": "/home/zzmjay/work/brd/stackup_yibo_202512042235.xml",
        "label": "Stackup XML"
      },
      {
        "name": "frequency",
        "type": "string",
        "default": "28GHz",
        "unit": "GHz",
        "label": "Adaptive frequency"
      },
      {
        "name": "sweep_start",
        "type": "string",
        "default": "0GHz",
        "unit": "GHz",
        "label": "Sweep start"
      },
      {
        "name": "sweep_stop",
        "type": "string",
        "default": "67GHz",
        "unit": "GHz",
        "label": "Sweep stop"
      },
      {
        "name": "sweep_points",
        "type": "integer",
        "default": 501,
        "label": "Sweep points"
      },
      {
        "name": "use_q3d_for_dc",
        "type": "boolean",
        "default": true,
        "label": "Use Q3D for DC point"
      },
      {
        "name": "solderball_diameter",
        "type": "string",
        "default": "20mil",
        "label": "Solder ball cylinder diameter"
      },
      {
        "name": "solderball_mid_diameter",
        "type": "string",
        "default": "20mil",
        "label": "Solder ball cylinder mid diameter"
      },
      {
        "name": "solderball_height",
        "type": "string",
        "default": "10mil",
        "label": "Solder ball cylinder height"
      },
      {
        "name": "solderball_material",
        "type": "string",
        "default": "solder",
        "label": "Solder ball cylinder material"
      },
      {
        "name": "artifact_dir",
        "type": "string",
        "default": "benchmarks/runs/stage_c1_demo_latest",
        "label": "Artifact directory"
      },
      {
        "name": "cutout_threads",
        "type": "integer",
        "default": 8,
        "label": "PyEDB cutout threads"
      }
    ],
    "nodes": [
      {
        "id": "discover_file",
        "node_id": "import_layout_file",
        "inputs": {
          "layout_file": {"$ref": "parameters.layout_file"},
          "output_dir": {"$ref": "parameters.artifact_dir"},
          "import_backend": "pyedb",
          "edb_backend": "auto"
        }
      },
      {
        "id": "select_nets",
        "node_id": "select_layout_nets",
        "inputs": {
          "signal_nets": {"$ref": "parameters.signal_nets"},
          "reference_nets": {"$ref": "parameters.reference_nets"}
        }
      },
      {
        "id": "cutout",
        "node_id": "create_layout_cutout",
        "inputs": {
          "layout": {"$ref": "discover_file.output.layout_path"},
          "signal_nets": {"$ref": "select_nets.output.signal_nets"},
          "reference_nets": {"$ref": "select_nets.output.reference_nets"},
          "expansion_size": 0.002,
          "extent_type": "ConvexHull",
          "threads": {"$ref": "parameters.cutout_threads"}
        }
      },
      {
        "id": "stackup",
        "node_id": "configure_layout_stackup",
        "inputs": {
          "layout": {"$ref": "cutout.output.cutout_name"},
          "stackup_rule": "load_stackup_xml",
          "stackup_xml": {"$ref": "parameters.stackup_xml"}
        }
      },
      {
        "id": "port_candidates",
        "node_id": "locate_layout_port_candidates",
        "inputs": {
          "layout": {"$ref": "cutout.output.cutout_name"},
          "signal_nets": {"$ref": "select_nets.output.signal_nets"},
          "reference_nets": {"$ref": "select_nets.output.reference_nets"},
          "candidate_rule": "differential_component_endpoints"
        }
      },
      {
        "id": "ports",
        "node_id": "create_layout_ports",
        "inputs": {
          "layout": {"$ref": "cutout.output.cutout_name"},
          "signal_nets": {"$ref": "select_nets.output.signal_nets"},
          "reference_nets": {"$ref": "select_nets.output.reference_nets"},
          "port_candidates": {"$ref": "port_candidates.output.candidate_report"},
          "port_rule": "component_cylinder_or_toggle_via_pin_gap_ports",
          "impedance": 50,
          "solderball_diameter": {"$ref": "parameters.solderball_diameter"},
          "solderball_mid_diameter": {"$ref": "parameters.solderball_mid_diameter"},
          "solderball_height": {"$ref": "parameters.solderball_height"},
          "solderball_material": {"$ref": "parameters.solderball_material"}
        }
      },
      {
        "id": "setup",
        "node_id": "create_layout_setup",
        "inputs": {
          "frequency": {"$ref": "parameters.frequency"},
          "sweep_start": {"$ref": "parameters.sweep_start"},
          "sweep_stop": {"$ref": "parameters.sweep_stop"},
          "sweep_type": "Interpolating",
          "sweep_points": {"$ref": "parameters.sweep_points"},
          "use_q3d_for_dc": {"$ref": "parameters.use_q3d_for_dc"},
          "name": "Setup1"
        }
      }
    ],
    "edges": [
      {"from": "discover_file.output.layout_path", "to": "cutout.inputs.layout"},
      {"from": "select_nets.output.signal_nets", "to": "cutout.inputs.signal_nets"},
      {"from": "select_nets.output.reference_nets", "to": "cutout.inputs.reference_nets"},
      {"from": "cutout.output.cutout_name", "to": "stackup.inputs.layout"},
      {"from": "cutout.output.cutout_name", "to": "port_candidates.inputs.layout"},
      {"from": "select_nets.output.signal_nets", "to": "port_candidates.inputs.signal_nets"},
      {"from": "select_nets.output.reference_nets", "to": "port_candidates.inputs.reference_nets"},
      {"from": "port_candidates.output.candidate_report", "to": "ports.inputs.port_candidates"},
      {"from": "cutout.output.cutout_name", "to": "ports.inputs.layout"}
    ],
    "validation": [],
    "outputs": [
      {
        "name": "aedt_project",
        "source": "discover_file.output.layout_path",
        "description": "Generated AEDT project for manual inspection."
      },
      {
        "name": "setup",
        "source": "setup.output.setup_name",
        "description": "Created 3D Layout setup and DC-to-67GHz sweep."
      }
    ],
    "metadata": {
      "stage": "C",
      "demo": true
    }
  }
}
