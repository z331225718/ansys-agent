{
  "template_id": "microstrip_sparameter",
  "name": "HFSS Microstrip S-Parameter",
  "description": "Create, excite with lumped ports, solve, and postprocess a minimal microstrip-like HFSS workflow.",
  "scenario": "Use this as a starter workflow for a visible end-to-end S-parameter demo.",
  "tags": ["hfss", "s-parameter", "microstrip", "starter"],
  "validation_checks": ["objects_exist", "material_matches", "boundary_created", "port_created", "setup_created", "sweep_created", "setup_solved", "sparameter_report_created"],
  "known_limits": ["This is a small demonstration model and is not intended as a production-grade microwave design."],
  "workflow": {
    "workflow_id": "microstrip_sparameter_v1",
    "name": "Microstrip S-Parameter",
    "version": "0.1.0",
    "description": "Starter workflow for a simple microstrip S-parameter setup.",
    "parameters": [
      {
        "name": "frequency",
        "type": "string",
        "default": "2.4GHz",
        "unit": "GHz",
        "label": "Adaptive frequency"
      },
      {
        "name": "sweep_stop",
        "type": "string",
        "default": "10GHz",
        "unit": "GHz",
        "label": "Sweep stop"
      },
      {
        "name": "artifact_dir",
        "type": "string",
        "default": "benchmarks/runs/stage_c1_demo_latest",
        "label": "Artifact directory"
      }
    ],
    "nodes": [
      {
        "id": "substrate",
        "node_id": "create_substrate",
        "inputs": {
          "origin": [-25, -10, 0],
          "size": [50, 20, 1.6],
          "material": "FR4_epoxy",
          "name": "Substrate"
        }
      },
      {
        "id": "trace",
        "node_id": "create_conductor_or_geometry_group",
        "inputs": {
          "geometry": [
            {
              "kind": "rectangle",
              "orientation": "XY",
              "origin": [-25, -10, 0],
              "size": [50, 20],
              "name": "Ground",
              "material": "copper"
            },
            {
              "kind": "rectangle",
              "orientation": "XY",
              "origin": [-20, -1, 1.6],
              "size": [40, 2],
              "name": "Trace",
              "material": "copper"
            },
            {
              "kind": "rectangle",
              "orientation": "YZ",
              "origin": [-20, -1, 0],
              "size": [2, 1.6],
              "name": "PortSheet1",
              "material": "vacuum"
            },
            {
              "kind": "rectangle",
              "orientation": "YZ",
              "origin": [20, -1, 0],
              "size": [2, 1.6],
              "name": "PortSheet2",
              "material": "vacuum"
            }
          ]
        }
      },
      {
        "id": "ground_pec",
        "node_id": "assign_boundary",
        "inputs": {
          "assignment": "Ground",
          "boundary_type": "Perfect_E",
          "name": "GroundPerfectE"
        }
      },
      {
        "id": "trace_pec",
        "node_id": "assign_boundary",
        "inputs": {
          "assignment": "Trace",
          "boundary_type": "Perfect_E",
          "name": "TracePerfectE"
        }
      },
      {
        "id": "airbox",
        "node_id": "create_airbox",
        "inputs": {
          "padding": 8,
          "name": "AirBox"
        }
      },
      {
        "id": "radiation",
        "node_id": "assign_boundary",
        "inputs": {
          "assignment": {
            "$ref": "airbox.output.object_name"
          },
          "boundary_type": "Radiation",
          "name": "Radiation"
        }
      },
      {
        "id": "lumped_port_1",
        "node_id": "create_port",
        "inputs": {
          "port_type": "lumped",
          "assignment": "PortSheet1",
          "impedance": 50,
          "integration_line": {
            "start": [-20, 0, 1.6],
            "end": [-20, 0, 0]
          },
          "name": "P1"
        }
      },
      {
        "id": "lumped_port_2",
        "node_id": "create_port",
        "inputs": {
          "port_type": "lumped",
          "assignment": "PortSheet2",
          "impedance": 50,
          "integration_line": {
            "start": [20, 0, 1.6],
            "end": [20, 0, 0]
          },
          "name": "P2"
        }
      },
      {
        "id": "setup",
        "node_id": "create_setup",
        "inputs": {
          "frequency": {
            "$ref": "parameters.frequency"
          },
          "name": "Setup1"
        }
      },
      {
        "id": "sweep",
        "node_id": "create_sweep_or_export",
        "inputs": {
          "setup": {
            "$ref": "setup.output.setup_name"
          },
          "start": "1GHz",
          "stop": {
            "$ref": "parameters.sweep_stop"
          },
          "points": 101,
          "name": "Sweep1"
        }
      },
      {
        "id": "solve",
        "node_id": "solve_setup",
        "inputs": {
          "setup": {
            "$ref": "setup.output.setup_name"
          }
        }
      },
      {
        "id": "postprocess",
        "node_id": "create_sparameter_report",
        "inputs": {
          "setup": {
            "$ref": "setup.output.setup_name"
          },
          "sweep": {
            "$ref": "sweep.output.sweep_name"
          },
          "ports": ["P1", "P2"],
          "report_name": "Demo S-Parameters",
          "touchstone_name": "microstrip_demo.s2p",
          "output_dir": {
            "$ref": "parameters.artifact_dir"
          }
        }
      }
    ],
    "edges": [
      {
        "from": "setup.output.setup_name",
        "to": "sweep.inputs.setup"
      },
      {
        "from": "setup.output.setup_name",
        "to": "solve.inputs.setup"
      },
      {
        "from": "setup.output.setup_name",
        "to": "postprocess.inputs.setup"
      },
      {
        "from": "sweep.output.sweep_name",
        "to": "postprocess.inputs.sweep"
      }
    ],
    "validation": [
      {"rule": "object_exists", "target": "Substrate"},
      {"rule": "object_exists", "target": "Ground"},
      {"rule": "boundary_exists", "target": "GroundPerfectE"},
      {"rule": "boundary_exists", "target": "TracePerfectE"},
      {"rule": "object_exists", "target": "AirBox"},
      {"rule": "boundary_exists", "target": "Radiation"},
      {"rule": "port_exists", "target": "P1"},
      {"rule": "port_exists", "target": "P2"},
      {"rule": "setup_exists", "target": "Setup1"},
      {"rule": "sweep_exists", "target": "Sweep1"},
      {"rule": "report_exists", "target": "Demo S-Parameters"}
    ],
    "outputs": [
      {
        "name": "setup",
        "source": "setup.output.setup_name",
        "description": "Created adaptive setup name."
      },
      {
        "name": "sweep",
        "source": "sweep.output.sweep_name",
        "description": "Created sweep name."
      },
      {
        "name": "touchstone",
        "source": "postprocess.output.touchstone_path",
        "description": "Exported Touchstone file."
      }
    ]
  }
}
